# Optional: comma-separated hostnames or IPs allowed for callback URL (e.g. 172.31.34.246,api.microsim.dev)
# SIMULATION_CALLBACK_WHITELIST=

# Simulation guardrails (Phase 1)
# Durations use Go syntax: 30s, 5m, 1h
# SIMD_MAX_STANDARD_DURATION=30m
# SIMD_MAX_WALL_CLOCK_RUNTIME=15m
#
# Integer limits
# SIMD_MAX_EVENTS_SCHEDULED=2000000
# SIMD_MAX_EVENTS_PROCESSED=2000000
# SIMD_MAX_EVENT_QUEUE_SIZE=200000
# SIMD_MAX_REQUESTS_TRACKED=200000
# SIMD_MAX_TOTAL_REQUESTS=2000000
# Completed request trace retention (Phase 4)
# SIMD_MAX_COMPLETED_REQUEST_TRACES=1000
# SIMD_REQUEST_TRACE_SAMPLING_RATE=1.0
# SIMD_MAX_METRIC_POINTS=1000000
# SIMD_MAX_METRIC_SERIES=10000
# SIMD_RUN_LATENCY_RESERVOIR_SIZE=2048
# SIMD_MAX_OPTIMIZATION_EVALUATIONS=1000
#
# RunStore lifecycle retention (Phase 5)
# SIMD_RUNSTORE_TTL=30m
# SIMD_RUNSTORE_CLEANUP_INTERVAL=1m
# SIMD_RUNSTORE_MAX_TERMINAL_RUNS=500
# SIMD_RUNSTORE_MAX_OPTIMIZATION_CANDIDATES=200
# SIMD_RUNSTORE_KEEP_COLLECTOR_AFTER_COMPLETION=false
#
# Optimization safety (Phase 6)
# SIMD_OPTIMIZATION_MAX_EVALUATIONS=128
# SIMD_OPTIMIZATION_MAX_ITERATIONS=20
# SIMD_OPTIMIZATION_MAX_CONCURRENT_CANDIDATES=2
# SIMD_OPTIMIZATION_MAX_WALL_CLOCK_RUNTIME=20m
# SIMD_OPTIMIZATION_CANDIDATE_MAX_WALL_CLOCK_RUNTIME=90s
# SIMD_OPTIMIZATION_MAX_FAILED_CANDIDATES=16
# SIMD_OPTIMIZATION_MAX_RETAINED_CANDIDATES=64
# SIMD_OPTIMIZATION_DEFAULT_EVALUATION_DURATION=10000
# SIMD_OPTIMIZATION_ALLOW_BATCH=true
