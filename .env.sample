# Optional: comma-separated hostnames or IPs allowed for callback URL (e.g. 172.31.34.246,api.microsim.dev)
# SIMULATION_CALLBACK_WHITELIST=

# Simulation guardrails (Phase 1)
# Durations use Go syntax: 30s, 5m, 1h
# SIMD_MAX_STANDARD_DURATION=30m
# SIMD_MAX_WALL_CLOCK_RUNTIME=15m
#
# Integer limits
# SIMD_MAX_EVENTS_SCHEDULED=2000000
# SIMD_MAX_EVENTS_PROCESSED=2000000
# SIMD_MAX_EVENT_QUEUE_SIZE=200000
# SIMD_MAX_REQUESTS_TRACKED=200000
# SIMD_MAX_METRIC_POINTS=1000000
# SIMD_MAX_OPTIMIZATION_EVALUATIONS=1000
